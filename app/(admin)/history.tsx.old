import React from 'react';
import { View, StyleSheet, FlatList } from 'react-native';
import { Text, Appbar, List, Divider, Surface, Chip } from 'react-native-paper';

const MOCK_LOGS = [
  { id: '1', name: 'Alice Martin', time: '08:30 AM', status: 'On-time', date: 'May 01' },
  { id: '2', name: 'Bob Chen', time: '08:45 AM', status: 'Late', date: 'May 01' },
  { id: '3', name: 'Aziz Elb', time: '09:00 AM', status: 'On-time', date: 'May 01' },
  { id: '4', name: 'Carol White', time: '08:15 AM', status: 'On-time', date: 'May 01' },
  { id: '5', name: 'David Lee', time: '09:20 AM', status: 'Late', date: 'May 01' },
];

export default function GlobalHistory() {
  const getStatusColor = (status: string) => {
    return status === 'On-time' ? '#4CAF50' : '#FF9800';
  };

  return (
    <View style={styles.container}>
      <Appbar.Header elevated>
        <Appbar.Content title="Attendance Logs" subtitle="All Activity" />
      </Appbar.Header>
      
      <View style={styles.content}>
        <Surface style={styles.surface} elevation={1}>
          <FlatList
            data={MOCK_LOGS}
            ItemSeparatorComponent={() => <Divider />}
            renderItem={({ item }) => (
              <List.Item
                title={item.name}
                description={`${item.date} | ${item.time}`}
                left={props => <List.Icon {...props} icon="account-clock" />}
                right={() => (
                  <Chip 
                    textStyle={{ color: 'white' }} 
                    style={{ backgroundColor: getStatusColor(item.status), alignSelf: 'center' }}
                  >
                    {item.status}
                  </Chip>
                )}
              />
            )}
            keyExtractor={item => item.id}
          />
        </Surface>
      </View>
    </View>
  );
}

const styles = StyleSheet.create({
  container: {
    flex: 1,
  },
  content: {
    flex: 1,
    padding: 16,
  },
  surface: {
    borderRadius: 12,
    overflow: 'hidden',
  }
});
